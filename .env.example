# Token do bot Telegram (via @BotFather)
BOT_TOKEN=

# Chave da API Anthropic (Claude) usada para o parse do texto livre da contagem
ANTHROPIC_API_KEY=

# String de conexão Postgres (porta 5433 no host — 5432 já está em uso por outro projeto local)
DATABASE_URL=postgresql://chefbot:chefbot@localhost:5433/chefbot

# Lista de telegram_ids autorizados a interagir com o bot, separados por vírgula
AUTHORIZED_TELEGRAM_IDS=

# telegram_id do responsável que recebe DM de escalonamento quando um alerta não é reconhecido a tempo
RESPONSAVEL_ESCALONAMENTO_TELEGRAM_ID=

# Minutos até um alerta não reconhecido escalar via DM (D2)
ALERT_TIMEOUT_MINUTES=15
