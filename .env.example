# Telegram bot token (via @BotFather)
BOT_TOKEN=

# Anthropic (Claude) API key used to parse the free-text count
ANTHROPIC_API_KEY=

# Gemini API key (C5/D10) — optional. Used only as a fallback when Claude times out or
# returns a 5xx/429. Without it, the bot works normally but without a fallback.
GEMINI_API_KEY=

# Postgres connection string (port 5433 on host — 5432 is already used by another local project)
DATABASE_URL=postgresql://chefbot:chefbot@localhost:5433/chefbot

# Módulo B (required as of B3 bot integration — /ingest_xml uses these):
# Google service account key for Drive access — full JSON content or base64-encoded
# JSON, never a .json file in the repo. Requires "drive.readonly" scope on the shared
# folder below.
GOOGLE_SERVICE_ACCOUNT_KEY=

# Drive folder id shared with the service account (chef-bot/<year>/<month>/<day>/*.xml)
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Comma-separated Telegram user ids allowed to run /ingest_xml (B3 bot integration).
# Empty means nobody can run it yet — not a boot failure.
ADMIN_TELEGRAM_IDS=
